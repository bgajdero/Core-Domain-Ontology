#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2006/time#Instant
<http://www.w3.org/2006/time#Instant> rdf:type owl:Class .


###  https://onto.colossi.network/cdo#Action
:Action rdf:type owl:Class ;
        rdfs:subClassOf :Active ;
        rdfs:comment "The execution of a transformation or harmonization operation."^^xsd:string .


###  https://onto.colossi.network/cdo#Active
:Active rdf:type owl:Class ;
        rdfs:subClassOf :Behaviour ;
        rdfs:comment "A manually triggered pipeline process for schema adjustments. (Action)"^^xsd:string .


###  https://onto.colossi.network/cdo#Attribute
:Attribute rdf:type owl:Class ;
           rdfs:subClassOf :CDOThing ;
           rdfs:comment "A specific metadata field (e.g., column name in a schema)."^^xsd:string .


###  https://onto.colossi.network/cdo#Behaviour
:Behaviour rdf:type owl:Class ;
           rdfs:subClassOf :CDOThing ;
           rdfs:comment "The monitoring of harmonization consistency across datasets. Superclass of Action and Object."^^xsd:string .


###  https://onto.colossi.network/cdo#CDOThing
:CDOThing rdf:type owl:Class ;
          rdfs:subClassOf owl:Thing ;
          rdfs:comment "CDOThing is the top CDO class."^^xsd:string .


###  https://onto.colossi.network/cdo#Cause
:Cause rdf:type owl:Class ;
       rdfs:subClassOf :CDOThing ;
       rdfs:comment "The causal relationship between raw data variations and harmonization requirements. Relates Action to Object)."^^xsd:string .


###  https://onto.colossi.network/cdo#Chart
:Chart rdf:type owl:Class ;
       rdfs:subClassOf :CDOThing ;
       rdfs:comment "The rendered display with data from the form."^^xsd:string .


###  https://onto.colossi.network/cdo#Concept
:Concept rdf:type owl:Class ;
         rdfs:subClassOf :Subjective ;
         rdfs:comment "The semantic mapping of schema elements to ontology terms."^^xsd:string .


###  https://onto.colossi.network/cdo#Data
:Data rdf:type owl:Class ;
      rdfs:subClassOf :CDOThing ;
      rdfs:comment "The structured and unstructured data ingested into the pipeline."^^xsd:string .


###  https://onto.colossi.network/cdo#Effect
:Effect rdf:type owl:Class ;
        rdfs:subClassOf :CDOThing ;
        rdfs:comment "The impact of schema standardization on downstream AI model performance. Relates Object to Event"^^xsd:string .


###  https://onto.colossi.network/cdo#Event
:Event rdf:type owl:Class ;
       rdfs:subClassOf :Objective ;
       rdfs:comment "A new dataset ingestion or schema synthesis process initiation."^^xsd:string .


###  https://onto.colossi.network/cdo#Fact
:Fact rdf:type owl:Class ;
      rdfs:subClassOf :CDOThing ;
      rdfs:comment "A verified, processed data point ensuring accuracy."^^xsd:string .


###  https://onto.colossi.network/cdo#Field
:Field rdf:type owl:Class ;
       rdfs:subClassOf :CDOThing ;
       rdfs:comment "A specific record field (e.g., a column within a structured dataset)."^^xsd:string .


###  https://onto.colossi.network/cdo#Form
:Form rdf:type owl:Class ;
      rdfs:subClassOf :CDOThing ;
      rdfs:comment "The DSL-formatted schema model used for standardization."^^xsd:string .


###  https://onto.colossi.network/cdo#Frame
:Frame rdf:type owl:Class ;
       rdfs:subClassOf :CDOThing ;
       rdfs:comment "The contextual metadata describing the relationship between schema attributes and ontology terms."^^xsd:string .


###  https://onto.colossi.network/cdo#Function
:Function rdf:type owl:Class ;
          rdfs:subClassOf :CDOThing ;
          rdfs:comment "The normalization and harmonization functions applied to data."^^xsd:string .


###  https://onto.colossi.network/cdo#Goal
:Goal rdf:type owl:Class ;
      rdfs:subClassOf :CDOThing ;
      rdfs:comment "The objec tive of transforming data into an AI-ready format. Relates Concept to Event."^^xsd:string .


###  https://onto.colossi.network/cdo#Interface
:Interface rdf:type owl:Class ;
           rdfs:subClassOf :CDOThing ;
           rdfs:comment "The API allowing external data sources to connect to the pipeline."^^xsd:string .


###  https://onto.colossi.network/cdo#Kernel
:Kernel rdf:type owl:Class ;
        rdfs:subClassOf :CDOThing ;
        rdfs:comment "The core processing unit performing schema synthesization."^^xsd:string .


###  https://onto.colossi.network/cdo#Ledger
:Ledger rdf:type owl:Class ;
        rdfs:subClassOf :CDOThing ;
        rdfs:comment "The immutable audit trail of all pipeline operations."^^xsd:string .


###  https://onto.colossi.network/cdo#Log
:Log rdf:type owl:Class ;
     rdfs:subClassOf :CDOThing ;
     rdfs:comment "The recorded process logs of the schema synthesization and transformation pipeline."^^xsd:string .


###  https://onto.colossi.network/cdo#Mechanism
:Mechanism rdf:type owl:Class ;
           rdfs:subClassOf :CDOThing ;
           rdfs:comment "The transformation logic applied to raw data during harmonization."^^xsd:string .


###  https://onto.colossi.network/cdo#Method
:Method rdf:type owl:Class ;
        rdfs:subClassOf :CDOThing ;
        rdfs:comment "The specific technique used for package harmonization and frame contextualization. Relates Action to Concept:"^^xsd:string .


###  https://onto.colossi.network/cdo#Note
:Note rdf:type owl:Class ;
      rdfs:subClassOf :CDOThing ;
      rdfs:comment "A record of human-interpreted decisions made in data transformation."^^xsd:string .


###  https://onto.colossi.network/cdo#Notice
:Notice rdf:type owl:Class ;
        rdfs:subClassOf :CDOThing ;
        rdfs:comment "A system alert regarding inconsistencies in harmonization or missing ontology mappings."^^xsd:string .


###  https://onto.colossi.network/cdo#Object
:Object rdf:type owl:Class ;
        rdfs:subClassOf :Passive ;
        rdfs:comment "The dataset ingested into the pipeline for processing."^^xsd:string .


###  https://onto.colossi.network/cdo#Objective
:Objective rdf:type owl:Class ;
           rdfs:subClassOf :Perspective ;
           rdfs:comment "The measurable accuracy of harmonized data transformation. Superclass of Event."^^xsd:string .


###  https://onto.colossi.network/cdo#Package
:Package rdf:type owl:Class ;
         rdfs:subClassOf :CDOThing ;
         rdfs:comment "The complete harmonized dataset with transformation instructions."^^xsd:string .


###  https://onto.colossi.network/cdo#Packet
:Packet rdf:type owl:Class ;
        rdfs:subClassOf :CDOThing ;
        rdfs:comment "A data bundle of structured metadata and schema updates."^^xsd:string .


###  https://onto.colossi.network/cdo#Passive
:Passive rdf:type owl:Class ;
         rdfs:subClassOf :Behaviour ;
         rdfs:comment "A background validation system ensuring harmonized data integrity. (Object)"^^xsd:string .


###  https://onto.colossi.network/cdo#Payload
:Payload rdf:type owl:Class ;
         rdfs:subClassOf :CDOThing ;
         rdfs:comment "The extracted and transformed structured dataset ready for training AI models."^^xsd:string .


###  https://onto.colossi.network/cdo#Perspective
:Perspective rdf:type owl:Class ;
             rdfs:subClassOf :CDOThing ;
             rdfs:comment "The interpretative stance on structuring AI training data. Can be an instance of either Subjective (superclass of Concept) or Objective (Superclass of Event)."^^xsd:string .


###  https://onto.colossi.network/cdo#Policy
:Policy rdf:type owl:Class ;
        rdfs:subClassOf :CDOThing ;
        rdfs:comment "The enforced data governance rules ensuring compliance."^^xsd:string .


###  https://onto.colossi.network/cdo#Purpose
:Purpose rdf:type owl:Class ;
         rdfs:subClassOf :CDOThing ;
         rdfs:comment "The intent behind structuring and harmonizing datasets for AI model training."^^xsd:string .


###  https://onto.colossi.network/cdo#Reason
:Reason rdf:type owl:Class ;
        rdfs:subClassOf :CDOThing ;
        rdfs:comment "The rationale for selecting specific schema transformations. Relates Action to Event."^^xsd:string .


###  https://onto.colossi.network/cdo#Receipt
:Receipt rdf:type owl:Class ;
         rdfs:subClassOf :CDOThing ;
         rdfs:comment "A cryptographic proof confirming a dataset transformation and validation."^^xsd:string .


###  https://onto.colossi.network/cdo#Record
:Record rdf:type owl:Class ;
        rdfs:subClassOf :CDOThing ;
        rdfs:comment "A harmonized data entry within the transformed dataset."^^xsd:string .


###  https://onto.colossi.network/cdo#Schema
:Schema rdf:type owl:Class ;
        rdfs:subClassOf :CDOThing ;
        rdfs:comment "The unified schema generated for harmonizing structured and unstructured data."^^xsd:string .


###  https://onto.colossi.network/cdo#Scheme
:Scheme rdf:type owl:Class ;
        rdfs:subClassOf :CDOThing ;
        rdfs:comment "The structured workflow guiding schema synthesis and frame contextualization. Relates Object to Concept."^^xsd:string .


###  https://onto.colossi.network/cdo#Shell
:Shell rdf:type owl:Class ;
       rdfs:subClassOf :CDOThing ;
       rdfs:comment "The secured environment protecting transformations at each stage."^^xsd:string .


###  https://onto.colossi.network/cdo#State
:State rdf:type owl:Class ;
       rdfs:subClassOf :CDOThing ;
       rdfs:comment "The current status of a dataset as it moves through pipeline stages."^^xsd:string .


###  https://onto.colossi.network/cdo#Statement
:Statement rdf:type owl:Class ;
           rdfs:subClassOf :CDOThing ;
           rdfs:comment "The declared compliance of a dataset with regulatory standards."^^xsd:string .


###  https://onto.colossi.network/cdo#Stemma
:Stemma rdf:type owl:Class ;
        rdfs:subClassOf :CDOThing ;
        rdfs:comment "The lineage representation of each transformation process, forming a full provenance record."^^xsd:string .


###  https://onto.colossi.network/cdo#Subjective
:Subjective rdf:type owl:Class ;
            rdfs:subClassOf :Perspective ;
            rdfs:comment "The human-defined priority of ontology terms within semantic mapping. (Concept)"^^xsd:string .


###  https://onto.colossi.network/cdo#Term
:Term rdf:type owl:Class ;
      rdfs:subClassOf :CDOThing ;
      rdfs:comment "A standardized term used for ontology-based contextualization."^^xsd:string .


###  https://onto.colossi.network/cdo#Text
:Text rdf:type owl:Class ;
      rdfs:subClassOf :CDOThing ;
      rdfs:comment "Unstructured data converted into structured format via NLP."^^xsd:string .


###  https://onto.colossi.network/cdo#Track
:Track rdf:type owl:Class ;
       rdfs:subClassOf :CDOThing ;
       rdfs:comment "The sequential tracking of dataset modifications across the pipeline."^^xsd:string .


###  https://onto.colossi.network/cdo#Value
:Value rdf:type owl:Class ;
       rdfs:subClassOf :CDOThing ;
       rdfs:comment "A computed quality score assessing data integrity."^^xsd:string .


