:Record_patient_1_blood_pressure_reading :isStemmaticTo :Log_blood_pressure_reading_1_3.
:Record_patient_2_blood_pressure_reading :isStemmaticTo :Log_blood_pressure_reading_2_1.
:Record_patient_2_blood_pressure_reading :isStemmaticTo :Log_blood_pressure_reading_2_2.
:Record_patient_2_blood_pressure_reading :isStemmaticTo :Log_blood_pressure_reading_2_3.
:Record_patient_3_blood_pressure_reading :isStemmaticTo :Log_blood_pressure_reading_3_1.
:Record_patient_3_blood_pressure_reading :isStemmaticTo :Log_blood_pressure_reading_3_2.
:Record_patient_3_blood_pressure_reading :isStemmaticTo :Log_blood_pressure_reading_3_3.

