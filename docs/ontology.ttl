                                            rdfs:domain <https://onto.colossi.network/cdo#Log> ;
                                            rdfs:range <http://www.w3.org/2006/time#Instant> ;
                                            rdfs:comment "The recorded process logs of the schema synthesization and transformation pipeline." .


