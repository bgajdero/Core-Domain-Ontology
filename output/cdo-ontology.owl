<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="https://onto.colossi.network/cdo"
         xmlns="https://onto.colossi.network/cdo#">

<owl:Ontology rdf:about="https://onto.colossi.network/cdo"/>

<owl:ObjectProperty rdf:about="#hasAttribute">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Attribute"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isProcessedBy">
  <rdfs:domain rdf:resource="#Attribute"/>
  <rdfs:range rdf:resource="#Kernel"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#structures">
  <rdfs:domain rdf:resource="#Kernel"/>
  <rdfs:range rdf:resource="#Schema"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isSystemicTo">
  <rdfs:domain rdf:resource="#Schema"/>
  <rdfs:range rdf:resource="#Form"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isVisualizedAs">
  <rdfs:domain rdf:resource="#Form"/>
  <rdfs:range rdf:resource="#Chart"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isEncodedAs">
  <rdfs:domain rdf:resource="#Chart"/>
  <rdfs:range rdf:resource="#Text"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#occursIn">
  <rdfs:domain rdf:resource="#Event"/>
  <rdfs:range rdf:resource="#Field"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isEncapsulatedBy">
  <rdfs:domain rdf:resource="#Field"/>
  <rdfs:range rdf:resource="#Shell"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isPartOf">
  <rdfs:domain rdf:resource="#Shell"/>
  <rdfs:range rdf:resource="#Record"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#loggedAt">
  <rdfs:domain rdf:resource="#Log"/>
  <rdfs:range rdf:resource="http://www.w3.org/2006/time#Instant"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isStemmaticTo">
  <rdfs:domain rdf:resource="#Record"/>
  <rdfs:range rdf:resource="#Log"/>
  <owl:inverseOf rdf:resource="#isComposedOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isComposedOf">
  <rdfs:domain rdf:resource="#Log"/>
  <rdfs:range rdf:resource="#Record"/>
  <owl:inverseOf rdf:resource="#isStemmaticTo"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isAggregatedIn">
  <rdfs:domain rdf:resource="#Log"/>
  <rdfs:range rdf:resource="#Ledger"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isTrackedBy">
  <rdfs:domain rdf:resource="#Ledger"/>
  <rdfs:range rdf:resource="#Track"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isRecordedIn">
  <rdfs:domain rdf:resource="#State"/>
  <rdfs:range rdf:resource="#Log"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#underpins">
  <rdfs:domain rdf:resource="#Text"/>
  <rdfs:range rdf:resource="#Stemma"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasLineage">
  <rdfs:domain rdf:resource="#Track"/>
  <rdfs:range rdf:resource="#Stemma"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#traces">
  <rdfs:domain rdf:resource="#Stemma"/>
  <rdfs:range rdf:resource="#Effect"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isRealizedThrough">
  <rdfs:domain rdf:resource="#Effect"/>
  <rdfs:range rdf:resource="#Mechanism"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#constructs">
  <rdfs:domain rdf:resource="#Mechanism"/>
  <rdfs:range rdf:resource="#Scheme"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasStructure">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Scheme"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#demonstrates">
  <rdfs:domain rdf:resource="#Event"/>
  <rdfs:range rdf:resource="#Effect"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isCausal">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Effect"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#enables">
  <rdfs:domain rdf:resource="#Form"/>
  <rdfs:range rdf:resource="#Mechanism"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#describedBy">
  <rdfs:domain rdf:resource="#Concept"/>
  <rdfs:range rdf:resource="#Term"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isExposedThrough">
  <rdfs:domain rdf:resource="#Term"/>
  <rdfs:range rdf:resource="#Interface"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isContexualizedBy">
  <rdfs:domain rdf:resource="#Interface"/>
  <rdfs:range rdf:resource="#Frame"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isEpistemicTo">
  <rdfs:domain rdf:resource="#Frame"/>
  <rdfs:range rdf:resource="#Notice"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#contains">
  <rdfs:domain rdf:resource="#Notice"/>
  <rdfs:range rdf:resource="#Frame"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isRegulatedBy">
  <rdfs:domain rdf:resource="#Notice"/>
  <rdfs:range rdf:resource="#Policy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isReferencedBy">
  <rdfs:domain rdf:resource="#Notice"/>
  <rdfs:range rdf:resource="#Policy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#contextualizes">
  <rdfs:domain rdf:resource="#Concept"/>
  <rdfs:range rdf:resource="#Object"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasKnowledge">
  <rdfs:domain rdf:resource="#Concept"/>
  <rdfs:range rdf:resource="#Scheme"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isAchieved">
  <rdfs:domain rdf:resource="#Event"/>
  <rdfs:range rdf:resource="#Goal"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#defines">
  <rdfs:domain rdf:resource="#Concept"/>
  <rdfs:range rdf:resource="#Goal"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#processes">
  <rdfs:domain rdf:resource="#Action"/>
  <rdfs:range rdf:resource="#Value"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isEnabledBy">
  <rdfs:domain rdf:resource="#Value"/>
  <rdfs:range rdf:resource="#Function"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isExecutedThrough">
  <rdfs:domain rdf:resource="#Function"/>
  <rdfs:range rdf:resource="#Packet"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isSystematic">
  <rdfs:domain rdf:resource="#Packet"/>
  <rdfs:range rdf:resource="#Payload"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isTransmittedBy">
  <rdfs:domain rdf:resource="#Payload"/>
  <rdfs:range rdf:resource="#Packet"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#encodes">
  <rdfs:domain rdf:resource="#Packet"/>
  <rdfs:range rdf:resource="#State"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isDeclaredBy">
  <rdfs:domain rdf:resource="#Payload"/>
  <rdfs:range rdf:resource="#Statement"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isAffirmedBy">
  <rdfs:domain rdf:resource="#Statement"/>
  <rdfs:range rdf:resource="#Fact"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#triggers">
  <rdfs:domain rdf:resource="#Action"/>
  <rdfs:range rdf:resource="#Event"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#instanceOf">
  <rdfs:domain rdf:resource="#Action"/>
  <rdfs:range rdf:resource="#Method"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isExpressedAs">
  <rdfs:domain rdf:resource="#Concept"/>
  <rdfs:range rdf:resource="#Method"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isJustifiedBy">
  <rdfs:domain rdf:resource="#Method"/>
  <rdfs:range rdf:resource="#Reason"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasIntelligence">
  <rdfs:domain rdf:resource="#Action"/>
  <rdfs:range rdf:resource="#Reason"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasCausality">
  <rdfs:domain rdf:resource="#Event"/>
  <rdfs:range rdf:resource="#Reason"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#fulfills">
  <rdfs:domain rdf:resource="#Method"/>
  <rdfs:range rdf:resource="#Purpose"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#guides">
  <rdfs:domain rdf:resource="#Purpose"/>
  <rdfs:range rdf:resource="#Reason"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#validates">
  <rdfs:domain rdf:resource="#Fact"/>
  <rdfs:range rdf:resource="#Package"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#utilizes">
  <rdfs:domain rdf:resource="#Package"/>
  <rdfs:range rdf:resource="#Method"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#formsBasisOf">
  <rdfs:domain rdf:resource="#Note"/>
  <rdfs:range rdf:resource="#Package"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#initiates">
  <rdfs:domain rdf:resource="#Action"/>
  <rdfs:range rdf:resource="#Cause"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isAffectedBy">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Cause"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#capturedAs">
  <rdfs:domain rdf:resource="#Data"/>
  <rdfs:range rdf:resource="#Object"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#exchangedThrough">
  <rdfs:domain rdf:resource="#Data"/>
  <rdfs:range rdf:resource="#Action"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#enteredAs">
  <rdfs:domain rdf:resource="#Data"/>
  <rdfs:range rdf:resource="#Event"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#accessedBy">
  <rdfs:domain rdf:resource="#Data"/>
  <rdfs:range rdf:resource="#Concept"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isLoggedAs">
  <rdfs:domain rdf:resource="#Packet"/>
  <rdfs:range rdf:resource="#Record"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#acknowledges">
  <rdfs:domain rdf:resource="#Receipt"/>
  <rdfs:range rdf:resource="#Payload"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isAcknowledgedBy">
  <rdfs:domain rdf:resource="#Record"/>
  <rdfs:range rdf:resource="#Receipt"/>
</owl:ObjectProperty>

<owl:Class rdf:about="#CDOThing">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CDOThing is the top CDO class.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Behaviour">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The monitoring of harmonization consistency across datasets. Superclass of Action and Object.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Passive">
  <rdfs:subClassOf rdf:resource="#Behaviour"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A background validation system ensuring harmonized data integrity. (Object)</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Active">
  <rdfs:subClassOf rdf:resource="#Behaviour"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A manually triggered pipeline process for schema adjustments. (Action)</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Perspective">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The interpretative stance on structuring AI training data. Can be an instance of either Subjective (superclass of Concept) or Objective (Superclass of Event).</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Objective">
  <rdfs:subClassOf rdf:resource="#Perspective"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The measurable accuracy of harmonized data transformation. Superclass of Event.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Subjective">
  <rdfs:subClassOf rdf:resource="#Perspective"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The human-defined priority of ontology terms within semantic mapping. (Concept)</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Object">
  <rdfs:subClassOf rdf:resource="#Passive"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The dataset ingested into the pipeline for processing.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Attribute">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A specific metadata field (e.g., column name in a schema).</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Form">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The DSL-formatted schema model used for standardization.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Kernel">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The core processing unit performing schema synthesization.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Schema">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The unified schema generated for harmonizing structured and unstructured data.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Chart">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The rendered display with data from the form.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Text">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unstructured data converted into structured format via NLP.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Event">
  <rdfs:subClassOf rdf:resource="#Objective"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A new dataset ingestion or schema synthesis process initiation.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Field">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A specific record field (e.g., a column within a structured dataset).</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Shell">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The secured environment protecting transformations at each stage.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Record">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A harmonized data entry within the transformed dataset.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Log">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The recorded process logs of the schema synthesization and transformation pipeline.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Ledger">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The immutable audit trail of all pipeline operations.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Track">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The sequential tracking of dataset modifications across the pipeline.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#State">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The current status of a dataset as it moves through pipeline stages.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Stemma">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The lineage representation of each transformation process, forming a full provenance record.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Effect">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The impact of schema standardization on downstream AI model performance. Relates Object to Event</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Mechanism">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The transformation logic applied to raw data during harmonization.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Scheme">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The structured workflow guiding schema synthesis and frame contextualization. Relates Object to Concept.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Concept">
  <rdfs:subClassOf rdf:resource="#Subjective"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The semantic mapping of schema elements to ontology terms.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Term">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A standardized term used for ontology-based contextualization.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Interface">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The API allowing external data sources to connect to the pipeline.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Frame">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The contextual metadata describing the relationship between schema attributes and ontology terms.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Notice">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A system alert regarding inconsistencies in harmonization or missing ontology mappings.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Policy">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The enforced data governance rules ensuring compliance.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Note">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A record of human-interpreted decisions made in data transformation.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Goal">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The objec tive of transforming data into an AI-ready format. Relates Concept to Event.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Action">
  <rdfs:subClassOf rdf:resource="#Active"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The execution of a transformation or harmonization operation.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Value">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A computed quality score assessing data integrity.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Function">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The normalization and harmonization functions applied to data.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Packet">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A data bundle of structured metadata and schema updates.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Payload">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The extracted and transformed structured dataset ready for training AI models.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Statement">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The declared compliance of a dataset with regulatory standards.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Fact">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A verified, processed data point ensuring accuracy.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Method">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The specific technique used for package harmonization and frame contextualization. Relates Action to Concept:</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Reason">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The rationale for selecting specific schema transformations. Relates Action to Event.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Purpose">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The intent behind structuring and harmonizing datasets for AI model training.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Package">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The complete harmonized dataset with transformation instructions.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Cause">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The causal relationship between raw data variations and harmonization requirements. Relates Action to Object).</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Data">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The structured and unstructured data ingested into the pipeline.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Receipt">
  <rdfs:subClassOf rdf:resource="#CDOThing"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A cryptographic proof confirming a dataset transformation and validation.</rdfs:comment>
</owl:Class>


</rdf:RDF>
