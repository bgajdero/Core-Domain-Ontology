    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://onto.colossi.network/cdo#accessedBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#accessedBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Domain"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Concept"/>
        <rdfs:comment>relates a Domain to a Concept, indicating that a Domain is accessed by a Concept.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#achieves -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#achieves">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Event"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Goal"/>
        <rdfs:comment>relates an Event to a Goal, indicating that an Event defines a Goal.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#acknowledges -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#acknowledges">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Receipt"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Packet"/>
        <rdfs:comment>relates a Receipt to a Packet, indicating that a Receipt acknowledges a Packet.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#affirms -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#affirms">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Statement"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Fact"/>
        <rdfs:comment>relates a Statement to a Fact, indicating that a Statement affirms a Fact.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#annotates -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#annotates">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Note"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Packet"/>
        <rdfs:comment>relates a Note to a Packet, indicating that a Note annotates a Packet.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#attributedTo -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#attributedTo">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Event"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Reason"/>
        <rdfs:comment>relates an Event to a Reason, indicating that an Event is attributed to a Reason.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#capturedAs -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#capturedAs">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Domain"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Object"/>
        <rdfs:comment>relates a Domain to an Object, indicating that a Domain is captured as an Object.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#constructs -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#constructs">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Mechanism"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Scheme"/>
        <rdfs:comment>relates a Mechanism to a Scheme, indicating that a Mechanism constructs a Scheme.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#contextualizes -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#contextualizes">
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Object"/>
        <rdfs:comment>relates a Object to a Concept, indicating that a Concept contexualizes an Object.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#conveys -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#conveys">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Packet"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Payload"/>
        <rdfs:comment>relates a Packet to a Payload, indicating that a Packet conveys a Method.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#declares -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#declares">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Packet"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Method"/>
        <rdfs:comment>relates a Packet to a Method, indicating that a Packet declares a Method.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#defines -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#defines">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Concept"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Goal"/>
        <rdfs:comment>relates a Concept to a Goal, indicating that a Concept defines a Goal.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#definesLayoutFor -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#definesLayoutFor">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Schema"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Form"/>
        <rdfs:comment>relates a Schema to a Form, indicating that a Schema defines layout for a Form.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#delivers -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#delivers">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Packet"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Statement"/>
        <rdfs:comment>relates a Packet to a Statement, indicating that a Packet delivers a Statement.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#encapsulates -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#encapsulates">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Function"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Payload"/>
        <rdfs:comment>relates a Function to a Payload, indicating that a Function encapsulates a Payload.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#encodes -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#encodes">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Payload"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#State"/>
        <rdfs:comment>relates a Payload to a State, indicating that a Payload encodes a State.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#enteredAs -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#enteredAs">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Domain"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Event"/>
        <rdfs:comment>relates a Domain to an Event, indicating that a Domain is entered as an Event.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#exchangedThrough -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#exchangedThrough">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Domain"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Action"/>
        <rdfs:comment>relates a Domain to an Action, indicating that a Domain is exchanged through an Action.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#fulfills -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#fulfills">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Method"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Purpose"/>
        <rdfs:comment>relates a Method to a Purpose, indicating that a Method fulfills a Purpose.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#guides -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#guides">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Purpose"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Reason"/>
        <rdfs:comment>relates a Purpose to a Reason, indicating that a Purpose guides a Reason.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#initiates -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#initiates">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Action"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Cause"/>
        <rdfs:comment>relates an Action to a Cause, indicating that an Action initiates a Cause.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#invokes -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#invokes">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Token"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Function"/>
        <rdfs:comment>relates a Token to a Function, indicating that a Token invokes a Function.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isAcknowledgedBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isAcknowledgedBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Notice"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Receipt"/>
        <rdfs:comment>relates a Notice to a Receipt, inverse of isAcknowlegedBy, indicating that a Notice is acknowledged by a Receipt.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isActivatedBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isActivatedBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Action"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Token"/>
        <rdfs:comment>relates an Action to a Token, indicating that an Action is activated by a Token.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isAddressedBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isAddressedBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Field"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Index"/>
        <rdfs:comment>relates a Field to an Index, indicating that a Field is addressed by an Index.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isAnnotatedBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isAnnotatedBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Chart"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Text"/>
        <rdfs:comment>relates a Chart to a Text, indicating that a Chart is annotated by a Text.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isBundledIn -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isBundledIn">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Card"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Schema"/>
        <rdfs:comment>relates a Card to a Schema, indicating that a Card is bundled in a Schema.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isCapturedBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isCapturedBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Payload"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Record"/>
        <rdfs:comment>relates a Payload to a Record, indicating that a Payload is capturted by a Record.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isCommittedTo -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isCommittedTo">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Record"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Log"/>
        <rdfs:comment>relates a Record to a Log, indicating that a Record is committed to a Log.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isConsumedBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isConsumedBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Form"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Mechanism"/>
        <rdfs:comment>relates a Form to a Mechanism, indicating that a Form is consumed by a Mechanism.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isDefinedBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isDefinedBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Concept"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Term"/>
        <rdfs:comment>relates a Concept to a Term, indicating that a Concept is defined by a Term.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isDescribedBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isDescribedBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Object"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Attribute"/>
        <rdfs:comment>relates an Object to an Attribute, indicating that an Object is described by an Attribute.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isDrivenBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isDrivenBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Action"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Reason"/>
        <rdfs:comment>relates an Action to a Reason, indicating that an Action is driven by a Reason.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isExplainedBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isExplainedBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Policy"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Note"/>
        <rdfs:comment>relates a Policy to a Note, indicating that a Policy is explained by a Note.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isImpactedBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isImpactedBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Object"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Cause"/>
        <rdfs:comment>relates an Object to a Cause, indicating that an Object is impacted by a Cause.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isInstanceOf -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isInstanceOf">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Action"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Method"/>
        <rdfs:comment>relates an Action to a Method, indicating that an Action is instance of a Method.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isIssuedUnder -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isIssuedUnder">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Receipt"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Policy"/>
        <rdfs:comment>relates a Receipt to a Policy, indicating that a Receipt is issued under (according to) a Policy.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isPackagedAs -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isPackagedAs">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Payload"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Package"/>
        <rdfs:comment>relates a Payload to a Package, indicating that a Payload is packaged as a Package.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isRealizedThrough -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isRealizedThrough">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Effect"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Mechanism"/>
        <rdfs:comment>relates an Effect to a Mechanism, indicating that an Effect is realized through a Mechanism.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isRecordedAs -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isRecordedAs">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Ledger"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Track"/>
        <rdfs:comment>relates a Ledger to a Track, indicating that a Ledger is recorded as a Track.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isRefinedBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isRefinedBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Term"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Parameter"/>
        <rdfs:comment>relates a Term to a Parameter, indicating that a Term is refined by a Parameter.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isRegisteredBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isRegisteredBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Index"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Record"/>
        <rdfs:comment>relates an Index to a Record, indicating that an Index is registered by a Record.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isRepresentedBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isRepresentedBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Attribute"/>
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#State"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Card"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Chart"/>
        <rdfs:comment>relates a Attribute to a Card, indicating that an Attribute is represented by a Card.</rdfs:comment>
        <rdfs:comment>relates a State to a Chart, indicating that a State is represented by a Chart.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isScopedBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isScopedBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Concept"/>
        <rdfs:range rdf:resource="https://onto.colossi.network/cdo#Scheme"/>
        <rdfs:comment>relates a Concept to a Scheme, indicating that a Concept is scoped by a Scheme.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://onto.colossi.network/cdo#isStructuredBy -->


    <owl:ObjectProperty rdf:about="https://onto.colossi.network/cdo#isStructuredBy">
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Object"/>
        <rdfs:domain rdf:resource="https://onto.colossi.network/cdo#Parameter"/>
