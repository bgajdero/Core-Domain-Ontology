@prefix : <https://onto.colossi.network/cdo#CoreDomainOntology> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://onto.colossi.network/cdo#CoreDomainOntology> .

<https://onto.colossi.network/cdo#CoreDomainOntology> rdf:type owl:Ontology ;
                                                       <http://creativecommons.org/ns#license> "http://creativecommons.org/licenses/by/3.0/" ;
                                                       <http://purl.org/dc/terms/creator> "Bart Gajderowicz (bart.gajderowicz@usu.edu" ,
                                                                                          "Keith Dugas (keith.dugas@secours.ai)" ,
                                                                                          "Paul Knowles (paul@secours.ai)" ;
                                                       <http://purl.org/dc/terms/issued> "2025-03-20"^^xsd:date ;
                                                       <http://purl.org/dc/terms/modified> "2026-03-11"^^xsd:date ;
                                                       <http://purl.org/dc/terms/rights> "Copyright @ 2026 Paul Knowles, Bart Gajderowicz, Keith Dugas" ;
                                                       <http://purl.org/dc/terms/title> "Core Domain Ontology" ;
                                                       <http://purl.org/vocab/vann/preferredNamespacePrefix> "cdo" ;
                                                       <http://purl.org/vocab/vann/preferredNamespaceUri> "https://onto.colossi.network/cdo#" ;
                                                       rdfs:comment """
Core Domain Ontology (CDO) is a semantic model developed to support the Informatics Domain Model IDM. 
The CDO is structured around five central nodes: objects, events, concepts, actions, and domain, which 
underpin various aspects of planning, reasoning, and execution in digital systems. It enables 
decentralized data representation, transformation, and alignment. 
                                """ ;
                                                       rdfs:label "Core Domain Ontology" ;
                                                       owl:versionInfo """
Version 1 March 11, 2026""" .

#################################################################
#    Annotation properties
#################################################################

###  http://creativecommons.org/ns#license
<http://creativecommons.org/ns#license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
<http://purl.org/dc/terms/issued> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/rights
<http://purl.org/dc/terms/rights> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://onto.colossi.network/cdo#accessedBy
<https://onto.colossi.network/cdo#accessedBy> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://onto.colossi.network/cdo#Domain> ;
                                              rdfs:range <https://onto.colossi.network/cdo#Concept> ;
                                              rdfs:comment "relates a Domain to a Concept, indicating that a Domain is accessed by a Concept." .


###  https://onto.colossi.network/cdo#acknowledges
<https://onto.colossi.network/cdo#acknowledges> rdf:type owl:ObjectProperty ;
                                                rdfs:domain <https://onto.colossi.network/cdo#Receipt> ;
                                                rdfs:range <https://onto.colossi.network/cdo#Notice> ;
                                                rdfs:comment "relates a Receipt to a Notice, indicating that a Receipt acknowledges a Notice." .


###  https://onto.colossi.network/cdo#affirms
<https://onto.colossi.network/cdo#affirms> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <https://onto.colossi.network/cdo#Statement> ;
                                           rdfs:range <https://onto.colossi.network/cdo#Fact> ;
                                           rdfs:comment "relates a Statement to a Fact, indicating that a Statement affirms a Fact." .


###  https://onto.colossi.network/cdo#aimsToward
<https://onto.colossi.network/cdo#aimsToward> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://onto.colossi.network/cdo#Behaviour> ;
                                              rdfs:range <https://onto.colossi.network/cdo#Goal> ;
                                              rdfs:comment "relates a Behaviour to a Goal, indicating that a Behaviour aims toward a Goal." .


###  https://onto.colossi.network/cdo#annotates
<https://onto.colossi.network/cdo#annotates> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <https://onto.colossi.network/cdo#Note> ;
                                             rdfs:range <https://onto.colossi.network/cdo#Text> ;
                                             rdfs:comment "relates a Note to a Text, indicating that a Note annotates a Text." .


###  https://onto.colossi.network/cdo#authorizes
<https://onto.colossi.network/cdo#authorizes> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://onto.colossi.network/cdo#Policy> ;
                                              rdfs:range <https://onto.colossi.network/cdo#Notice> ;
                                              rdfs:comment "relates a Policy to a Notice, indicating that a Policy authorizes a Notice." .


###  https://onto.colossi.network/cdo#capturedAs
<https://onto.colossi.network/cdo#capturedAs> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://onto.colossi.network/cdo#Domain> ;
                                              rdfs:range <https://onto.colossi.network/cdo#Object> ;
                                              rdfs:comment "relates a Domain to an Object, indicating that a Domain is captured as an Object." .


###  https://onto.colossi.network/cdo#conditions
<https://onto.colossi.network/cdo#conditions> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://onto.colossi.network/cdo#Passive> ;
                                              rdfs:range <https://onto.colossi.network/cdo#Behaviour> ;
                                              rdfs:comment "relates a Passive to a Behaviour, indicating that a Passive conditions a Behaviour." .


###  https://onto.colossi.network/cdo#constructs
<https://onto.colossi.network/cdo#constructs> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://onto.colossi.network/cdo#Mechanism> ;
                                              rdfs:range <https://onto.colossi.network/cdo#Scheme> ;
                                              rdfs:comment "relates a Mechanism to a Scheme, indicating that a Mechanism constructs a Scheme." .


###  https://onto.colossi.network/cdo#defines
<https://onto.colossi.network/cdo#defines> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <https://onto.colossi.network/cdo#Concept> ;
                                           rdfs:range <https://onto.colossi.network/cdo#Term> ;
                                           rdfs:comment "relates a Concept to a Term, indicating that a Concept defines a Term." .


###  https://onto.colossi.network/cdo#definesLayoutFor
<https://onto.colossi.network/cdo#definesLayoutFor> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <https://onto.colossi.network/cdo#Schema> ;
                                                    rdfs:range <https://onto.colossi.network/cdo#Form> ;
                                                    rdfs:comment "relates a Schema to a Form, indicating that a Schema defines layout for a Form." .


###  https://onto.colossi.network/cdo#delivers
<https://onto.colossi.network/cdo#delivers> rdf:type owl:ObjectProperty ;
                                            rdfs:domain <https://onto.colossi.network/cdo#Packet> ;
                                            rdfs:range <https://onto.colossi.network/cdo#Statement> ;
                                            rdfs:comment "relates a Packet to a Statement, indicating that a Packet delivers a Statement." .


###  https://onto.colossi.network/cdo#documents
<https://onto.colossi.network/cdo#documents> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <https://onto.colossi.network/cdo#Record> ;
                                             rdfs:range <https://onto.colossi.network/cdo#Note> ;
                                             rdfs:comment "relates a Record to a Note, indicating that a Record documents a Note." .


