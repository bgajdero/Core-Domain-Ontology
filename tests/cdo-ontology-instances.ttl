:Event_hospital_y_admission_recorded :occursIn :Field_blood_presure_reading.
:Event_hospital_z_admission_recorded :occursIn :Field_blood_presure_reading.

:Field_blood_presure_reading :isEncapsulatedBy :Shell_blood_pressure_calculations.
:Field_blood_presure_reading :isEncapsulatedBy :Shell_blood_pressure_calculations.
:Field_blood_presure_reading :isEncapsulatedBy :Shell_blood_pressure_calculations.

