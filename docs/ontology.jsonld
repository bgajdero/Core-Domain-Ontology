[ {
  "@id" : "http://creativecommons.org/ns#license",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/creator",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/description",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/issued",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/modified",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/rights",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/title",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/vocab/vann/preferredNamespacePrefix",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/vocab/vann/preferredNamespaceUri",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2001/XMLSchema#date",
  "@type" : [ "http://www.w3.org/2000/01/rdf-schema#Datatype" ]
}, {
  "@id" : "http://www.w3.org/2006/time#Instant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Action",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "an intentional operation performed within a computational system that acts upon data to achieve a specific outcome, such as creation, transformation, transmission, or deletion."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://onto.colossi.network/cdo#Active"
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Active",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "data that is currently in use, being processed, or engaged in real-time operations within a computational system, often contributing to immediate functions, decisions, or interactions."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://onto.colossi.network/cdo#Behaviour"
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Attribute",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a defined unit of information within a data object that expresses a specific property, characteristic, or qualifier used to describe, differentiate, or structure the underlying entity."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Behaviour",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "the observable pattern of responses, interactions, or state changes exhibited by data within a computational system in reaction to specific inputs, conditions, or stimuli."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Card",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "the central structural element within a data object that governs how its attributes are organized, interpreted, or processed within a given computational or semantic framework."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Cause",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "an identified factor or trigger within a computational system that initiates or gives rise to a data event, state change, or processing action, often captured for traceability or causal analysis."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Chart",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a visual representation of structured data within a computational system, expressed through tables, graphs, or diagrams to reveal patterns, trends, or relationships for interpretation or analysis."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Concept",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "an abstract, structured idea within a computational system that provides semantic meaning or contextual framing to data, enabling consistent interpretation, classification, and interoperability across domains."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://onto.colossi.network/cdo#Subjective"
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#CoreDomainOntology",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://creativecommons.org/ns#license" : [ {
    "@value" : "http://creativecommons.org/licenses/by/3.0/"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Bart Gajderowicz (bart.gajderowicz@usu.edu"
  }, {
    "@value" : "Keith Dugas (keith.dugas@secours.ai)"
  }, {
    "@value" : "Paul Knowles (paul@secours.ai)"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "\nCore Domain Ontology (CDO) is a semantic model developed to support the Informatics Domain Model IDM. \nThe CDO is structured around five central nodes: objects, events, concepts, actions, and domain, which \nunderpin various aspects of planning, reasoning, and execution in digital systems. It enables \ndecentralized data representation, transformation, and alignment. \n                                "
  } ],
  "http://purl.org/dc/terms/issued" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2025-03-20"
  } ],
  "http://purl.org/dc/terms/modified" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-03-11"
  } ],
  "http://purl.org/dc/terms/rights" : [ {
    "@value" : "Copyright @ 2026 Paul Knowles, Bart Gajderowicz, Keith Dugas"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@value" : "Core Domain Ontology"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "cdo"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@value" : "https://onto.colossi.network/cdo#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Core Domain Ontology"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "\nVersion 1 March 11, 2026"
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Domain",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "facts and statistics entered into a computational system, structured for reference, processing, or analysis within a defined informational context."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Effect",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a resulting change or outcome within a computational system that occurs as a consequence of a specific data cause, action, or condition, often used to evaluate impact or derive meaning."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Event",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a recorded occurrence within a computational system that captures a change of state, action, or condition in time, often triggering processes or serving as a reference point in data trails."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://onto.colossi.network/cdo#Objective"
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Fact",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a verified unit of information within a computational system that represents an objective truth or observed reality, serving as a foundational element for analysis, inference, or decision-making."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Field",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a designated element within a data structure that holds a specific value corresponding to a defined attribute, enabling organized storage, access, and retrieval of information in a computational system."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Form",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a particular configuration or expression of data shaped by its structure, type, or representation within a computational system, often determining how it is stored, displayed, or exchanged."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Frame",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a semantic structure within a computational system that organizes and contextualizes data by linking attributes to concepts, enabling meaningful interpretation, interoperability, and knowledge representation."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Function",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a discrete, executable operation within a computational system that performs a defined task on data—such as computation, transformation, retrieval, or validation—to support a broader process or outcome."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Goal",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a defined objective or desired outcome that guides the collection, processing, or analysis of data within a computational system, often shaping methodologies, metrics, or system behavior."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Index",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a structured containment layer that encapsulates one or more fields, defining local boundaries, validation logic, and schema constraints within a form or data model."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Ledger",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "an ordered and immutable collection of data logs or events maintained within a computational system to provide a verifiable record of actions, transactions, or changes over time."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Log",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a chronological record of system-generated or user-triggered events captured within a computational system to support monitoring, auditing, debugging, or traceability."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Mechanism",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "an established structural or procedural construct within a computational system that enables the flow, transformation, or enforcement of rules upon data as part of a broader operational process."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Method",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a defined and repeatable procedure within a computational system used to process, analyze, or manipulate data according to a systematic approach or established protocol."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Note",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a brief annotation or explanatory comment attached to a data element within a computational system, providing contextual insight, clarification, or guidance without altering the underlying data."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Notice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a time-sensitive notification within a computational system that conveys important information, conditions, or changes related to data, prompting awareness, preparation, or responsive action."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Object",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a structured data construct within a computational system that represents a defined entity or data model that encapsulates both its attributes and kernels for its structural interpretation or operation."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://onto.colossi.network/cdo#Passive"
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Objective",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "data that represents observable facts or measurable phenomena within a computational system, recorded without personal bias or interpretation and verifiable through consistent methods or standards."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://onto.colossi.network/cdo#Perspective"
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Package",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a bundled collection of programs or subroutines within a computational system, organized for coherent transport, processing, or reuse as a functional unit."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Packet",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a structured unit of data formatted for transmission within or between computational systems, containing both payload and control information to ensure proper delivery, interpretation, and routing."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Parameter",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a semantic modifier within a computational system that refines the intent, scope, or behavior of a term or command, enabling contextual interpretation and meaningful configuration."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Passive",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "data that resides in a computational system without actively influencing or participating in current processes, typically stored for reference, archival, or deferred analysis."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://onto.colossi.network/cdo#Behaviour"
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Payload",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "the core content or meaningful information carried within a data packet, excluding metadata or control structures, and intended for processing, storage, or interpretation by the receiving system."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Perspective",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a specific contextual or interpretive viewpoint applied to data within a computational system, shaping how it is understood, framed, or utilized based on user roles, objectives, or analytical models."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Policy",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a defined set of principles or rules within a computational system that governs the collection, usage, access, sharing, or retention of data to ensure compliance, security, and ethical management."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Purpose",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "the declared operational reason within a computational or analytical context for which data is collected, processed, or utilized, distinct from legal justification and focused on functional intent at the data layer."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Reason",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "an explanatory reference within a computational system that justifies or clarifies the motivation behind a specific data-related action, decision, or condition, distinct from legal or policy mandates."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Receipt",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a recorded acknowledgment within a computational system confirming the successful reception of a data object, message, or transaction, often including metadata such as timestamp, source, and verification status."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Record",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a structured collection of related data fields treated as a single unit within a computational system, typically representing an instance of an entity or event for storage, retrieval, or processing."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Schema",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a structured framework that defines the organization, types, and relationships of data attributes within a data object, guiding its validation, interpretation, and integration in computational systems."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Scheme",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a defined and ordered arrangement of related data structures—such as schemas, fields, or classification systems—within a computational system, used to organize, relate, and standardize data across contexts."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#State",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "the specific condition or configuration of a data object or system component at a given point in time, reflecting its current values, status, or operational context within a computational process."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Statement",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a clearly defined expression of a fact, rule, or condition within a computational system, often used to declare, assert, or instruct how data should be processed, interpreted, or constrained."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Stemma",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a branching diagram or structural lineage within a computational system that traces the derivation, transformation, or version history of data across sources or processes."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Subjective",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "data that reflects personal opinions, interpretations, emotions, or perceptions captured within a computational system, often influenced by individual experience or context rather than objective measurement."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://onto.colossi.network/cdo#Perspective"
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Term",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a defined word or phrase used within a computational system to label, express, or reference a data concept, enabling standardized interpretation and communication across structured data environments."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Text",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "alphanumeric content within a computational system that conveys human-readable information, typically used for labels, descriptions, entries, or communication in structured or unstructured formats."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Token",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a discrete invocation unit within a computational system that conveys delegated authority and actively initiates the execution of specific actions or functions, serving as a proximal trigger within controlled workflows."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#Track",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a structured sequence of linked data points or events within a computational system that traces the progression, movement, or lifecycle of an entity or process over time."
  } ]
}, {
  "@id" : "https://onto.colossi.network/cdo#accessedBy",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "relates a Domain to a Concept, indicating that a Domain is accessed by a Concept."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://onto.colossi.network/cdo#Domain"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://onto.colossi.network/cdo#Concept"
  } ]
}, {
